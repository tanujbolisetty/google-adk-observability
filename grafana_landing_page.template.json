    {
      "type": "text",
      "title": "Welcome to Agent Analytics",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "options": {
        "content": "# \ud83d\udcca Agent Intelligence Dashboard\nWelcome! Use the navigation bar above to explore your agent telemetry.",
        "mode": "markdown"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Total Sessions",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "rawSql": "SELECT count(DISTINCT session_id) as total_sessions FROM `${gcp_project}.${bq_dataset}.v_session_summary` WHERE $__timeFilter(session_start)",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "description": "Unique count of session IDs initiated by users in the selected time range."
    },
    {
      "type": "stat",
      "title": "Total Tokens",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 5
      },
      "targets": [
        {
          "rawSql": "SELECT sum(session_total_tokens) as tokens FROM `${gcp_project}.${bq_dataset}.v_session_summary` WHERE $__timeFilter(session_start)",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Cumulative tokens consumed (Prompt + Completion). Automatically scales (K, M, B)."
    },
    {
      "type": "stat",
      "title": "Total Cost (USD)",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT sum(session_total_cost_usd) as usd_cost FROM `${gcp_project}.${bq_dataset}.v_session_summary` WHERE $__timeFilter(session_start)",
          "format": "table"
        }
      ],
      "description": "Estimated cumulative cost in USD based on model pricing and token usage."
    },
    {
      "type": "timeseries",
      "title": "\ud83d\udcc8 Sessions Per Day",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "rawSql": "SELECT TIMESTAMP(DATE(session_start)) AS time, COUNT(DISTINCT session_id) AS value FROM `${gcp_project}.${bq_dataset}.v_session_summary` WHERE $__timeFilter(session_start) GROUP BY 1 ORDER BY 1",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "\ud83d\udcc8 Daily Token Consumption",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "rawSql": "SELECT TIMESTAMP(DATE(session_start)) AS time, SUM(session_total_tokens) AS value FROM `${gcp_project}.${bq_dataset}.v_session_summary` WHERE $__timeFilter(session_start) GROUP BY 1 ORDER BY 1",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "type": "table",
      "title": "Recent Sessions by User",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "rawSql": "SELECT session_id, user_id, session_start, session_end, total_turns, session_total_tokens, session_total_cost_usd FROM `${gcp_project}.${bq_dataset}.v_session_summary` WHERE $__timeFilter(session_start) ORDER BY session_start DESC LIMIT 20",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "description": "Latest 20 user sessions with activity and cost summaries."
    }
  ],
