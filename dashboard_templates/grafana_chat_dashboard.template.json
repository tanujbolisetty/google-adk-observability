{
  "title": "Agent Transcript (Chat Logs)",
  "uid": "agent-transcript",
  "tags": [
    "agent",
    "adk",
    "agent-chat"
  ],
  "editable": true,
  "schemaVersion": 39,
  "description": "Conversation transcripts and session performance profile.",
  "timezone": "browser",
  "links": [],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data Source",
        "type": "datasource",
        "query": "grafana-bigquery-datasource",
        "current": { "text": "BigQuery", "value": "BigQuery" },
        "hide": 0
      },
      {
        "name": "gcp_project",
        "label": "GCP Project",
        "type": "textbox",
        "current": { "text": "your-project-id", "value": "your-project-id" },
        "hide": 0
      },
      {
        "name": "bq_dataset",
        "label": "BQ Dataset",
        "type": "textbox",
        "current": { "text": "your-dataset-id", "value": "your-dataset-id" },
        "hide": 0
      },
      {
        "name": "bq_table",
        "label": "Base Table",
        "type": "textbox",
        "current": { "text": "your-table-name", "value": "your-table-name" },
        "hide": 0
      },
      {
        "name": "user_id",
        "label": "User",
        "type": "query",
        "hide": 0,
        "query": {
          "rawSql": "SELECT 'Select_User' as user_id UNION ALL (SELECT user_id FROM (SELECT user_id, MAX(session_start) as last_seen FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE user_id IS NOT NULL AND $__timeFilter(session_start) GROUP BY 1 ORDER BY last_seen DESC LIMIT 1000))",
          "rawQuery": true,
          "editorMode": "code",
          "format": 1
        },
        "sort": 0,
        "refresh": 2,
        "includeAll": false,
        "current": {
          "text": "Select_User",
          "value": "Select_User"
        },
        "options": [
          {
            "selected": true,
            "text": "Select_User",
            "value": "Select_User"
          }
        ],
        "datasource": {
          "type": "grafana-bigquery-datasource",
          "uid": "${datasource}"
        }
      },
      {
        "name": "session_id",
        "label": "Session",
        "type": "query",
        "hide": 0,
        "query": {
          "rawSql": "SELECT 'Select_Session' as session_id UNION ALL (SELECT session_id FROM (SELECT session_id, MAX(timestamp) as last_seen FROM `${gcp_project}.${bq_dataset}.${bq_table}` WHERE user_id = '${user_id:raw}' AND '${user_id:raw}' NOT IN ('Select_User', '--', 'All') AND $__timeFilter(timestamp) GROUP BY 1 ORDER BY last_seen DESC LIMIT 1000))",
          "rawQuery": true,
          "editorMode": "code",
          "format": 1
        },
        "sort": 0,
        "refresh": 2,
        "includeAll": false,
        "current": {
          "text": "Select_Session",
          "value": "Select_Session"
        },
        "options": [
          {
            "selected": true,
            "text": "Select_Session",
            "value": "Select_Session"
          }
        ],
        "datasource": {
          "type": "grafana-bigquery-datasource",
          "uid": "${datasource}"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 999,
      "options": {
        "content": "<div style=\"display: flex; flex-direction: column; align-items: center; gap: 8px; width: 100%;\">\n  <div style=\"display: flex; gap: 24px; font-size: 14px; font-weight: bold; justify-content: center; align-items: center; width: 100%;\">\n    <div style=\"display: flex; gap: 16px; align-items: center; padding: 8px 16px; background: rgba(128,128,128,0.1); border-radius: 8px; border: 1px solid rgba(128,128,128,0.2);\">\n      <span style=\"color: #8e8e8e; font-size: 11px; text-transform: uppercase; letter-spacing: 1px;\">\ud83d\udcca SUMMARY</span>\n      <a href=\"/d/agent-landing?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}\" style=\"text-decoration: none; color: #5794F2;\">\ud83c\udfe0 Home</a>\n      <a href=\"/d/agent-finops?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83d\udcb0 FinOps</a>\n      <a href=\"/d/agent-diagnostics?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83d\udee0\ufe0f Diagnostics</a>\n    </div>\n    <div style=\"display: flex; gap: 16px; align-items: center; padding: 8px 16px; background: rgba(128,128,128,0.1); border-radius: 8px; border: 1px solid rgba(128,128,128,0.2);\">\n      <span style=\"color: #8e8e8e; font-size: 11px; text-transform: uppercase; letter-spacing: 1px;\">\ud83d\udd0d FORENSICS</span>\n      <a href=\"/d/agent-transcript?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83d\udcac Transcripts</a>\n      <a href=\"/d/agent-traces?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83d\udcdc Traces</a>\n      <a href=\"/d/agent-llm-audit?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83e\udde0 LLM Audit</a>\n    </div>\n    <div style=\"display: flex; gap: 16px; align-items: center; padding: 8px 16px; background: rgba(128,128,128,0.1); border-radius: 8px; border: 1px solid rgba(128,128,128,0.2);\">\n      <span style=\"color: #8e8e8e; font-size: 11px; text-transform: uppercase; letter-spacing: 1px;\">\ud83d\udcd6 GUIDE</span>\n      <a href=\"/d/agent-guide?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83d\udcd6 Guide</a>\n    </div>\n  </div>\n  <div style=\"display: flex; gap: 24px; font-size: 11px; color: #8e8e8e; justify-content: center; align-items: center; border-top: 1px solid rgba(128,128,128,0.2); padding-top: 8px; width: 100%;\">\n    <span>\ud83c\udf10 <b>Project:</b> ${gcp_project} &nbsp;&nbsp; | &nbsp;&nbsp; \ud83d\udcc2 <b>Dataset:</b> ${bq_dataset}</span>\n  </div>\n  <div style=\"display: flex; gap: 24px; font-size: 11px; color: #8e8e8e; justify-content: center; align-items: center; width: 100%;\">\n    <span>\ud83d\udcc4 <b>Table:</b> ${bq_table} &nbsp;&nbsp; | &nbsp;&nbsp; \ud83d\udd0c <b>Source:</b> ${datasource}</span>\n  </div>\n</div>",
        "mode": "html"
      },
      "transparent": true
    },
    {
      "type": "table",
      "title": "\ud83d\udcac Conversation Flow (Synchronized Transcript)",
      "gridPos": {
        "h": 26,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "id": 1,
      "options": {
        "showHeader": true,
        "cellHeight": "auto",
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "text"
            },
            "inspect": true,
            "filterable": true,
            "wrapText": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "speaker"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "time"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "message"
            },
            "properties": [
              {
                "id": "custom.wrapText",
                "value": true
              },
              {
                "id": "custom.inspect",
                "value": true
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "auto"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "duration_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          },
          "format": "table",
          "rawSql": "SELECT timestamp as time, speaker, message, TIMESTAMP_DIFF(timestamp, LAG(timestamp) OVER (ORDER BY timestamp ASC), MILLISECOND) as duration_ms FROM `${gcp_project}.${bq_dataset}.v_aaa_session_transcript` WHERE session_id = '${session_id:raw}' AND $__timeFilter(timestamp) ORDER BY time ASC",
          "refId": "A"
        }
      ]
    }
  ],
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}