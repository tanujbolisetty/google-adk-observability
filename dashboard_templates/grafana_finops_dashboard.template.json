{
  "title": "Agent FinOps (Token Costs)",
  "uid": "agent-finops",
  "tags": [
    "agent",
    "adk",
    "agent-financials"
  ],
  "editable": true,
  "schemaVersion": 39,
  "description": "Token usage and cost breakdown. [FILTERS]: User ID (Global)",
  "timezone": "browser",
  "links": [],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data Source",
        "type": "datasource",
        "query": "grafana-bigquery-datasource",
        "current": { "text": "BigQuery", "value": "BigQuery" },
        "hide": 0
      },
      {
        "name": "gcp_project",
        "label": "GCP Project",
        "type": "textbox",
        "current": { "text": "your-project-id", "value": "your-project-id" },
        "hide": 0
      },
      {
        "name": "bq_dataset",
        "label": "BQ Dataset",
        "type": "textbox",
        "current": { "text": "your-dataset-id", "value": "your-dataset-id" },
        "hide": 0
      },
      {
        "name": "bq_table",
        "label": "Base Table",
        "type": "textbox",
        "current": { "text": "your-table-name", "value": "your-table-name" },
        "hide": 0
      },
      {
        "name": "application",
        "label": "Application",
        "type": "query",
        "hide": 0,
        "query": {
          "rawSql": "SELECT DISTINCT app_name FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE app_name IS NOT NULL AND $__timeFilter(session_start) ORDER BY app_name",
          "rawQuery": true,
          "editorMode": "code",
          "format": 1
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": "Select_Application",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "grafana-bigquery-datasource",
          "uid": "${datasource}"
        }
      },
      {
        "name": "user_id",
        "label": "User",
        "type": "query",
        "hide": 0,
        "query": {
          "rawSql": "SELECT DISTINCT user_id FROM (SELECT user_id, MAX(session_start) as last_seen FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE user_id IS NOT NULL AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND $__timeFilter(session_start) GROUP BY 1 ORDER BY last_seen DESC LIMIT 1000)",
          "rawQuery": true,
          "editorMode": "code",
          "format": 1
        },
        "sort": 0,
        "refresh": 2,
        "includeAll": true,
        "allValue": "Select_User",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": "All"
          }
        ],
        "datasource": {
          "type": "grafana-bigquery-datasource",
          "uid": "${datasource}"
        }
      },
      {
        "name": "session_id",
        "label": "Session",
        "type": "query",
        "hide": 0,
        "query": {
          "rawSql": "SELECT DISTINCT session_id FROM (SELECT session_id, MAX(timestamp) as last_seen FROM `${gcp_project}.${bq_dataset}.${bq_table}` WHERE (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('Select_User', '--', '', 'All', '$__all')) AND (JSON_VALUE(attributes, '$.session_metadata.app_name') = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND $__timeFilter(timestamp) GROUP BY 1 ORDER BY last_seen DESC LIMIT 1000)",
          "rawQuery": true,
          "editorMode": "code",
          "format": 1
        },
        "sort": 0,
        "refresh": 2,
        "includeAll": true,
        "allValue": "Select_Session",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": "All"
          }
        ],
        "datasource": {
          "type": "grafana-bigquery-datasource",
          "uid": "${datasource}"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 999,
      "options": {
        "content": "<div style=\"display: flex; flex-direction: column; align-items: center; gap: 8px; width: 100%;\">\n  <div style=\"display: flex; gap: 24px; font-size: 14px; font-weight: bold; justify-content: center; align-items: center; width: 100%;\">\n    <div style=\"display: flex; gap: 16px; align-items: center; padding: 8px 16px; background: rgba(128,128,128,0.1); border-radius: 8px; border: 1px solid rgba(128,128,128,0.2);\">\n      <span style=\"color: #8e8e8e; font-size: 11px; text-transform: uppercase; letter-spacing: 1px;\">\ud83d\udcca SUMMARY</span>\n      <a href=\"/d/agent-landing?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-application=${application}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83c\udfe0 Home</a>\n      <a href=\"/d/agent-finops?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-application=${application}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83d\udcb0 FinOps</a>\n      <a href=\"/d/agent-diagnostics?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-application=${application}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83d\udee0\ufe0f Diagnostics</a>\n    </div>\n    <div style=\"display: flex; gap: 16px; align-items: center; padding: 8px 16px; background: rgba(128,128,128,0.1); border-radius: 8px; border: 1px solid rgba(128,128,128,0.2);\">\n      <span style=\"color: #8e8e8e; font-size: 11px; text-transform: uppercase; letter-spacing: 1px;\">\ud83d\udd0d FORENSICS</span>\n      <a href=\"/d/agent-transcript?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-application=${application}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83d\udcac Transcripts</a>\n      <a href=\"/d/agent-traces?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-application=${application}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83d\udcdc Traces</a>\n      <a href=\"/d/agent-llm-audit?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-application=${application}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83e\udde0 LLM Audit</a>\n    </div>\n    <div style=\"display: flex; gap: 16px; align-items: center; padding: 8px 16px; background: rgba(128,128,128,0.1); border-radius: 8px; border: 1px solid rgba(128,128,128,0.2);\">\n      <span style=\"color: #8e8e8e; font-size: 11px; text-transform: uppercase; letter-spacing: 1px;\">\ud83d\udcd6 GUIDE</span>\n      <a href=\"/d/agent-guide?${__url_time_range}&var-datasource=${datasource}&var-gcp_project=${gcp_project}&var-bq_dataset=${bq_dataset}&var-bq_table=${bq_table}&var-application=${application}&var-user_id=${user_id}&var-session_id=${session_id}\" style=\"text-decoration: none; color: #5794F2;\">\ud83d\udcd6 Guide</a>\n    </div>\n  </div>\n  <div style=\"display: flex; gap: 24px; font-size: 11px; color: #8e8e8e; justify-content: center; align-items: center; border-top: 1px solid rgba(128,128,128,0.2); padding-top: 8px; width: 100%;\">\n    <span>\ud83c\udf10 <b>Project:</b> ${gcp_project} &nbsp;&nbsp; | &nbsp;&nbsp; \ud83d\udcc2 <b>Dataset:</b> ${bq_dataset}</span>\n  </div>\n  <div style=\"display: flex; gap: 24px; font-size: 11px; color: #8e8e8e; justify-content: center; align-items: center; width: 100%;\">\n    <span>\ud83d\udcc4 <b>Table:</b> ${bq_table} &nbsp;&nbsp; | &nbsp;&nbsp; \ud83d\udd0c <b>Source:</b> ${datasource}</span>\n  </div>\n</div>",
        "mode": "html"
      },
      "transparent": true
    },
    {
      "type": "timeseries",
      "title": "\ud83d\udcb5 Session Cost Over Time (USD)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "points",
            "pointSize": 6,
            "showPoints": "always",
            "lineInterpolation": "linear",
            "lineWidth": 1
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "#73BF69"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT session_start AS time, session_total_cost_usd AS value, session_id, user_id FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE $__timeFilter(session_start) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session', '$__all', '--', '')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User', '$__all', '--', '')) ORDER BY time",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "showLegend": false,
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      }
    },
    {
      "type": "timeseries",
      "title": "\ud83d\udd22 Tokens Consumed Per Turn",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "lineWidth": 1
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT turn_start AS time, tokens AS value, session_id, user_id FROM `${gcp_project}.${bq_dataset}.v_aaa_turn_summary` WHERE $__timeFilter(turn_start) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session', '$__all', '--', '')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User', '$__all', '--', '')) ORDER BY time",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "showLegend": false,
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      }
    },
    {
      "type": "barchart",
      "title": "\ud83d\udcca Token Usage by Model Version",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.7
      },
      "targets": [
        {
          "rawSql": "SELECT model, SUM(total_tokens) as total_tokens, SUM(calculated_usd_cost) as total_cost_usd FROM `${gcp_project}.${bq_dataset}.v_aaa_llm_calls` WHERE $__timeFilter(timestamp) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session', '$__all', '--', '')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User', '$__all', '--', '')) GROUP BY model ORDER BY total_tokens DESC",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "table",
      "title": "\ud83d\udccb Cost Breakdown Per Session",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "app_name"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Application"
              },
              {
                "id": "custom.width",
                "value": 150
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total_cost_usd"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Cost (USD)"
              },
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "session_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "\ud83d\udd0d Drill into Traces",
                    "url": "/d/agent-traces?${__url_time_range}&var-session_id=${__value.text}&var-user_id=${__data.fields.user_id}"
                  },
                  {
                    "title": "\ud83d\udcac View Chat Transcript",
                    "url": "/d/agent-transcript?${__url_time_range}&var-session_id=${__value.text}&var-user_id=${__data.fields.user_id}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT l.app_name, l.session_id, l.user_id, SUM(l.calculated_usd_cost) as total_cost_usd, MIN(l.timestamp) as session_start, SUM(l.prompt_tokens) as input_tokens, SUM(l.completion_tokens) as output_tokens, SUM(l.total_tokens) as total_tokens FROM `${gcp_project}.${bq_dataset}.v_aaa_llm_calls` l WHERE $__timeFilter(l.timestamp) AND (l.app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (l.session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session', '$__all', '--', '')) AND (l.user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User', '$__all', '--', '')) GROUP BY l.app_name, l.session_id, l.user_id ORDER BY session_start DESC LIMIT 20",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "barchart",
      "title": "\ud83e\udd16 Token Usage by Specialist",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.7
      },
      "targets": [
        {
          "rawSql": "SELECT agent as specialist, SUM(total_tokens) as total_tokens FROM `${gcp_project}.${bq_dataset}.v_aaa_llm_calls` WHERE $__timeFilter(timestamp) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('Select_Session', '--', '', 'All', '$__all')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('Select_User', '--', '', 'All', '$__all')) GROUP BY specialist ORDER BY total_tokens DESC",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "barchart",
      "title": "\ud83d\udc64 Top 10 Spenders (USD)",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "fixed",
            "fixedColor": "#73BF69"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.7
      },
      "targets": [
        {
          "rawSql": "SELECT user_id, SUM(session_total_cost_usd) as total_cost_usd FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE $__timeFilter(session_start) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('Select_User', '--', '', 'All', '$__all')) GROUP BY user_id ORDER BY total_cost_usd DESC LIMIT 10",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ]
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}