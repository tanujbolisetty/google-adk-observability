      "targets": [
        {
          "rawSql": "SELECT app_name, SUM(session_total_tokens) as total_tokens FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE $__timeFilter(session_start) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session')) GROUP BY app_name ORDER BY total_tokens DESC",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ],
      "id": 15
    },

