    {
      "type": "barchart",
      "title": "\ud83d\udcb0 Token Usage by Application",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.7
