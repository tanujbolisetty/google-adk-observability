    {
      "type": "text",
      "title": "Welcome to Google ADK Agent Analytics",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "options": {
        "content": "# \ud83d\udcca Agent Intelligence Dashboard\nWelcome! Use the navigation bar above to explore your agent telemetry.",
        "mode": "markdown"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "id": 2
    },
    {
      "type": "stat",
      "title": "Total Sessions",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "rawSql": "SELECT count(DISTINCT session_id) as total_sessions FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE $__timeFilter(session_start) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session'))",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "description": "Unique count of session IDs initiated by users in the selected time range.",
      "id": 3
    },
    {
      "type": "stat",
      "title": "Total User Questions",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 7
      },
      "targets": [
        {
          "rawSql": "SELECT count(*) as total_questions FROM `${gcp_project}.${bq_dataset}.v_aaa_user_intent` WHERE $__timeFilter(timestamp) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session'))",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "description": "Total number of human-initiated questions/prompts processed by the agent within the selected timeframe (questions count across all sessions during the timeframe).",
      "id": 4
    },
    {
      "type": "stat",
      "title": "Total Tokens",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 7
      },
      "targets": [
        {
          "rawSql": "SELECT sum(session_total_tokens) as tokens FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE $__timeFilter(session_start) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session'))",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "description": "Cumulative tokens consumed (Prompt + Completion). Automatically scales (K, M, B).",
      "id": 5
    },
    {
      "type": "stat",
      "title": "Total Cost (USD)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT sum(session_total_cost_usd) as cost FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE $__timeFilter(session_start) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session'))",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ],
      "description": "Estimated cumulative cost in USD based on model pricing and token usage.",
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "\ud83d\udcc8 Sessions Per Day",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "rawSql": "SELECT TIMESTAMP(DATE(session_start)) AS time, COUNT(DISTINCT session_id) AS value, app_name FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE $__timeFilter(session_start) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session')) GROUP BY 1, 3 ORDER BY 1",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 20,
            "barAlignment": 0,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "time"
            },
            "properties": [
              {
                "id": "unit",
                "value": "time:MM/DD"
              }
            ]
          }
        ]
      },
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "\ud83d\udcca Questions Per Day",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "rawSql": "SELECT TIMESTAMP(DATE(timestamp)) AS time, COUNT(*) AS value, app_name FROM `${gcp_project}.${bq_dataset}.v_aaa_user_intent` WHERE $__timeFilter(timestamp) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session')) GROUP BY 1, 3 ORDER BY 1",
          "format": "table",
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${datasource}"
