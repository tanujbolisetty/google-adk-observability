      "targets": [
        {
          "rawSql": "SELECT TIMESTAMP(DATE(session_start)) AS time, SUM(session_total_tokens) AS value, app_name FROM `${gcp_project}.${bq_dataset}.v_aaa_session_summary` WHERE $__timeFilter(session_start) AND (app_name = '${application:raw}' OR '${application:raw}' IN ('All', 'Select_Application', '$__all')) AND (user_id = '${user_id:raw}' OR '${user_id:raw}' IN ('All', 'Select_User')) AND (session_id = '${session_id:raw}' OR '${session_id:raw}' IN ('All', 'Select_Session')) GROUP BY 1, 3 ORDER BY 1",
