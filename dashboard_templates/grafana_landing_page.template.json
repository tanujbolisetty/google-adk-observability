                "value": 2
              },
              {
                "id": "custom.stacking",
                "value": {
                  "mode": "none"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "id": 8
