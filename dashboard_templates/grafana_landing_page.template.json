      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 20,
            "barAlignment": 0,
            "lineWidth": 1,
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "gradientMode": "opacity",
            "stacking": {
              "group": "A",
              "mode": "normal"
